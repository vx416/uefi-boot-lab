# Local VM / Vagrant state
.vagrant/

# EDK2 local build output generated inside this package when building in-place.
Build/
Conf/
*.efi
*.debug
*.map
*.pdb

# End-to-end test output and generated boot media.
artifacts/
*.fd
*.iso
*.img
*.img.tmp
*.raw
*.qcow2
*.vhd
*.vmdk

# Runtime logs and serial captures.
*.log
*.trace

# Python cache / local tooling state.
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.venv/
venv/

# Local environment files.
.env
.env.*
!.env.example

# Private scratch notes. Curated docs/ content is intended to be tracked.
notes/

# OS / editor noise.
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
